# Shared auth — OpenWA webhook header → backend validation
GATEWAY_SECRET_TOKEN=change-me-before-use

# OpenWA session name (used when calling OpenWA API)
OPENWA_SESSION_ID=ops_gateway_main

# Ollama — must be running on the host at port 11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=10

# Classifier threshold — messages below this confidence are discarded
MIN_CONFIDENCE=0.65

# Dashboard page title
DASHBOARD_TITLE=Ops Incident Monitor

# PostgreSQL — used by both docker-compose and the backend service
POSTGRES_DB=ops_incidents
POSTGRES_USER=ops_user
POSTGRES_PASSWORD=change-me-too
DATABASE_URL=postgresql+asyncpg://ops_user:change-me-too@postgres:5432/ops_incidents
