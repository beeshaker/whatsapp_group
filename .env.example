# Shared auth — OpenWA webhook header → backend validation
GATEWAY_SECRET_TOKEN=change-me-before-use

# Session cookie signing key
SECRET_KEY=change-me-before-use

# OpenWA session name (used when calling OpenWA API)
OPENWA_SESSION=opsgateway
OPENWA_API_KEY=change-me-before-use
OPENWA_URL=http://openwa:2785

# Ollama — must be running on the host at port 11434
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60

# Classifier threshold — messages below this confidence are discarded
MIN_CONFIDENCE=0.80

# Dashboard
DASHBOARD_TITLE=Ops Incident Monitor
DASHBOARD_URL=http://localhost:8000
SUMMARY_TIMEZONE=Africa/Nairobi
SUMMARY_SCHEDULE_HOUR=8

# Admin accounts — seeded on first startup if users table is empty
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-use
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me-before-use

# PostgreSQL
POSTGRES_DB=ops_incidents
POSTGRES_USER=ops_user
POSTGRES_PASSWORD=change-me-too
DATABASE_URL=postgresql+asyncpg://ops_user:change-me-too@postgres:5432/ops_incidents
