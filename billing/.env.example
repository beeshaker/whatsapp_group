# Billing service config — copy to .env and fill in

# PostgreSQL (create database saas_billing first)
DATABASE_URL=postgresql+asyncpg://billing_user:billing-db-pass@localhost:5432/saas_billing

# Admin login for the billing dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-strong-password

# Session signing key (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Webhook auth — must match BILLING_WEBHOOK_SECRET in every client backend .env
BILLING_WEBHOOK_SECRET=

# MPesa Daraja credentials (get from https://developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_ENV=sandbox

# Public URL for MPesa callback (must be reachable by Safaricom — set up Nginx to proxy this)
MPESA_CALLBACK_BASE_URL=https://whats2eat.com/billing
