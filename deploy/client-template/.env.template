# ─── Ports (set before docker compose up) ───────────────────────────────────
BACKEND_PORT=8001
OPENWA_PORT=2001

# ─── PostgreSQL (shared server, dedicated database) ──────────────────────────
POSTGRES_USER=ops_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=client_CLIENTNAME
DATABASE_URL=postgresql+asyncpg://ops_user:CHANGE_THIS_STRONG_PASSWORD@host.docker.internal:5432/client_CLIENTNAME

# ─── Security (generate unique values per client) ────────────────────────────
# Run: openssl rand -hex 32
GATEWAY_SECRET_TOKEN=GENERATE_RANDOM_TOKEN
SECRET_KEY=GENERATE_RANDOM_TOKEN

# ─── Admin accounts (seeded on first startup) ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# ─── WhatsApp / OpenWA ───────────────────────────────────────────────────────
OPENWA_URL=http://openwa:2785
OPENWA_SESSION=CLIENTNAME
OPENWA_API_KEY=GENERATE_RANDOM_TOKEN

# ─── Ollama (shared host instance) ───────────────────────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60
MIN_CONFIDENCE=0.80

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_TITLE=CLIENTNAME Incident Monitor
DASHBOARD_URL=https://CLIENTNAME.yourdomain.com
SUMMARY_TIMEZONE=Africa/Nairobi
SUMMARY_SCHEDULE_HOUR=8
